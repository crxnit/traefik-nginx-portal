# Documenso — env template. Copy to .env, fill in, mode 600, owned by portal.
# Generate the three crypto secrets fresh: `openssl rand -base64 32`.
# LOSING NEXT_PRIVATE_ENCRYPTION_* MAKES EXISTING DOCUMENTS UNDECRYPTABLE —
# back this file up to your secret store the moment you finish editing it.

# ── Postgres (consumed by the postgres service AND embedded in DATABASE_URL)
POSTGRES_USER=documenso
POSTGRES_PASSWORD=CHANGEME-strong-random-password
POSTGRES_DB=documenso

# ── App URLs
# Public URL is what users see; must match the FQDN you provisioned via portal.
NEXT_PUBLIC_WEBAPP_URL=https://sign.example.com
# Internal URL is how the container reaches itself (for background jobs).
NEXT_PRIVATE_INTERNAL_WEBAPP_URL=http://documenso-backend:3000

# ── Database connection
# Host = postgres service name, port = 5432 inside the documenso-internal network.
NEXT_PRIVATE_DATABASE_URL=postgresql://documenso:CHANGEME-strong-random-password@documenso-postgres:5432/documenso
NEXT_PRIVATE_DIRECT_DATABASE_URL=postgresql://documenso:CHANGEME-strong-random-password@documenso-postgres:5432/documenso

# ── Auth + crypto (REQUIRED). Generate each with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGEME-openssl-rand-base64-32
NEXT_PRIVATE_ENCRYPTION_KEY=CHANGEME-openssl-rand-base64-32
NEXT_PRIVATE_ENCRYPTION_SECONDARY_KEY=CHANGEME-openssl-rand-base64-32

# ── PDF signing certificate
# Cert lives at /opt/documenso/cert.p12 inside the container (bind-mount from
# ./certs/cert.p12). Self-signed is fine for in-house signing; CA-issued is
# needed for legally-recognized signatures in some jurisdictions.
NEXT_PRIVATE_SIGNING_TRANSPORT=local
NEXT_PRIVATE_SIGNING_LOCAL_FILE_PATH=/opt/documenso/cert.p12
NEXT_PRIVATE_SIGNING_PASSPHRASE=CHANGEME-cert-passphrase

# ── File storage
# `database` keeps PDFs in Postgres (simple; bloats the DB at scale).
# `s3` requires the NEXT_PRIVATE_UPLOAD_* vars below.
NEXT_PUBLIC_UPLOAD_TRANSPORT=database
# NEXT_PRIVATE_UPLOAD_ENDPOINT=
# NEXT_PRIVATE_UPLOAD_REGION=us-east-1
# NEXT_PRIVATE_UPLOAD_BUCKET=
# NEXT_PRIVATE_UPLOAD_ACCESS_KEY_ID=
# NEXT_PRIVATE_UPLOAD_SECRET_ACCESS_KEY=
# NEXT_PRIVATE_UPLOAD_FORCE_PATH_STYLE=false

# Max upload size in MB. nginx client_max_body_size must be >= this value.
NEXT_PUBLIC_DOCUMENT_SIZE_UPLOAD_LIMIT=50

# ── Outbound mail (REQUIRED — recipients receive sign links by email)
# Documenso supports smtp-auth | smtp-api | mailchannels | resend.
NEXT_PRIVATE_SMTP_TRANSPORT=smtp-auth
NEXT_PRIVATE_SMTP_HOST=smtp.example.com
NEXT_PRIVATE_SMTP_PORT=587
NEXT_PRIVATE_SMTP_SECURE=false
NEXT_PRIVATE_SMTP_USERNAME=
NEXT_PRIVATE_SMTP_PASSWORD=
NEXT_PRIVATE_SMTP_FROM_NAME=Documenso
NEXT_PRIVATE_SMTP_FROM_ADDRESS=noreply@example.com

# ── Optional: lock signups to a single domain (or comma-separated list).
# NEXT_PUBLIC_DISABLE_SIGNUP=false
# NEXT_PRIVATE_ALLOWED_SIGNUP_DOMAINS=example.com
