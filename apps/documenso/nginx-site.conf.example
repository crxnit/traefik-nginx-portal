# Example: nginx/conf.d/sign.example.com.conf after hand-editing the file
# generated by `portal provision-site sign.example.com`.
#
# Replace the entire static-content server block with this. The static-only
# generator output is wrong for Documenso — it's a fully-proxied Next.js app,
# not path-split static + API.
#
# Substitute every "sign.example.com" below with your real FQDN.

server {
    listen 80;
    server_name sign.example.com;

    # PDF uploads. Must be >= NEXT_PUBLIC_DOCUMENT_SIZE_UPLOAD_LIMIT in .env.
    # Default nginx limit is 1m, which would 413 on any real document.
    client_max_body_size 50m;

    # Documenso owns every path. No static fallthrough.
    location / {
        proxy_pass http://documenso-backend:3000;

        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;

        # PDF rendering can take a while on large documents.
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }
}
