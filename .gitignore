# Secrets — ACME private keys and self-signed default TLS cert
traefik/acme.json
traefik/certs/

# Compose env + OAuth credentials (Google client ID/secret, cookie-signing key,
# whitelist domain, COMPOSE_PROFILES). Written by install.sh at mode 600.
.env

# Generated per-site Traefik dynamic files; keep underscore-prefixed shared files
traefik/dynamic/*.yml
traefik/dynamic/*.yaml
!traefik/dynamic/_*.yml
!traefik/dynamic/_*.yaml

# Generated per-site nginx configs; keep default catchall
nginx/conf.d/*.conf
!nginx/conf.d/00-default.conf

# Provisioned site content; keep the default landing page
nginx/sites/*
!nginx/sites/default/

# Binary blobs / backup archives
archive/

# Runtime artifacts
.portal.lock
logs/

# OS / editor cruft
.DS_Store
*.swp

# Claude Code local session state
.claude/
